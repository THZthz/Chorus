{
  "name": "chorus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "server": "tsx src/server/main.ts",
    "server:dev": "tsx --watch src/server/main.ts",
    "console": "tsx src/console/main.ts",
    "mcp": "tsx src/server/mcp.ts",
    "lint": "tsc --noEmit",
    "add-license": "node scripts/add-license-header.mjs",
    "clean": "rm -rf dist",
    "format": "npx prettier --write \"(src|tests)/**/*.{js,ts,tsx}\"",
    "format:check": "npx prettier --check \"(src|tests)/**/*.{js,ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:scenarios": "vitest run tests/scenarios/",
    "knip": "knip"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/google": "^3.0.3",
    "@ai-sdk/openai": "^3.0.4",
    "@inquirer/prompts": "^8.4.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.188",
    "chalk": "^5.6.2",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonrepair": "^3.14.0",
    "log-update": "^8.0.0",
    "neo4j-driver": "^6.0.1",
    "partial-json": "^0.1.7",
    "smol-toml": "^1.6.1",
    "uuid": "^11.1.0",
    "wrap-ansi": "^9.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/devtools": "^0.0.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.19",
    "@types/uuid": "^10.0.0",
    "knip": "^6.13.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^4.1.6"
  }
}
